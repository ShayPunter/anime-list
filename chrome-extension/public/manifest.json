{
    "manifest_version": 3,
    "name": "AniTrack",
    "short_name": "AniTrack",
    "description": "Quickly manage your AniTrack anime list — search, track progress, and update entries without leaving your tab.",
    "version": "0.1.0",
    "action": {
        "default_popup": "src/popup/index.html",
        "default_title": "AniTrack"
    },
    "background": {
        "service_worker": "background.js",
        "type": "module"
    },
    "permissions": ["storage"],
    "host_permissions": [
        "http://localhost:8000/*",
        "http://127.0.0.1:8000/*",
        "https://anitrack.app/*"
    ],
    "icons": {
        "16": "icons/icon-16.png",
        "32": "icons/icon-32.png",
        "48": "icons/icon-48.png",
        "128": "icons/icon-128.png"
    }
}
