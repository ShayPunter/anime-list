{
    "$schema": "https://www.schemastore.org/package.json",
    "name": "anitrack-chrome-extension",
    "private": true,
    "type": "module",
    "version": "0.1.0",
    "description": "Chrome extension for AniTrack — quick anime list management.",
    "scripts": {
        "dev": "vite build --watch --mode development",
        "build": "vue-tsc --noEmit && vite build",
        "type-check": "vue-tsc --noEmit",
        "package": "vite build && cd dist && zip -r ../anitrack-extension.zip ."
    },
    "devDependencies": {
        "@types/chrome": "^0.0.287",
        "@vitejs/plugin-vue": "^6.0.4",
        "typescript": "~5.9.3",
        "vite": "^7.3.1",
        "vue-tsc": "^3.2.5"
    },
    "dependencies": {
        "vue": "^3.5.29"
    }
}
